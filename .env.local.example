# Supabase — get these from Project Settings > API at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Ads API — from Google Cloud Console
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/connect/google/callback

# Meta (Facebook) Ads API — from developers.facebook.com
META_APP_ID=your-app-id
META_APP_SECRET=your-app-secret
META_REDIRECT_URI=http://localhost:3000/api/connect/meta/callback

# LinkedIn Ads API — from LinkedIn Developer Portal (Marketing Developer Platform)
# Requires MDP approval for r_ads and r_ads_reporting scopes
LINKEDIN_ADS_CLIENT_ID=your-client-id
LINKEDIN_ADS_CLIENT_SECRET=your-client-secret
LINKEDIN_ADS_REDIRECT_URI=http://localhost:3000/api/connect/linkedin/callback

# TikTok Ads API — from TikTok for Business Developer Portal
TIKTOK_ADS_APP_ID=your-app-id
TIKTOK_ADS_APP_SECRET=your-app-secret
TIKTOK_ADS_REDIRECT_URI=http://localhost:3000/api/connect/tiktok/callback
