generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  password      String
  firstName     String?
  lastName      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  adAccounts    AdAccount[]

  @@map("users")
}

model AdAccount {
  id              String        @id @default(uuid())
  userId          String
  platform        Platform
  accountId       String
  accountName     String?
  accessToken     String
  refreshToken    String?
  tokenExpiresAt  DateTime?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics         AdMetric[]

  @@unique([platform, accountId])
  @@map("ad_accounts")
}

enum Platform {
  GOOGLE_ADS
  FACEBOOK_ADS
}

model AdMetric {
  id              String        @id @default(uuid())
  adAccountId     String
  date            DateTime

  // Core metrics
  impressions     Int           @default(0)
  clicks          Int           @default(0)
  spend           Float         @default(0)
  conversions     Int           @default(0)

  // Calculated metrics
  ctr             Float?        // Click-through rate
  cpc             Float?        // Cost per click
  cpm             Float?        // Cost per thousand impressions
  conversionRate  Float?        // Conversion rate
  cpa             Float?        // Cost per acquisition

  // Additional dimensions
  campaignId      String?
  campaignName    String?
  adSetId         String?
  adSetName       String?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  adAccount       AdAccount     @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  @@unique([adAccountId, date, campaignId])
  @@index([date])
  @@index([adAccountId, date])
  @@map("ad_metrics")
}

model BenchmarkSnapshot {
  id                    String    @id @default(uuid())
  date                  DateTime
  platform              Platform?

  // Aggregated metrics across all users
  totalUsers            Int
  avgImpressions        Float
  avgClicks             Float
  avgSpend              Float
  avgConversions        Float
  avgCtr                Float
  avgCpc                Float
  avgCpm                Float
  avgConversionRate     Float
  avgCpa                Float

  // Percentile data for better comparison
  p25Ctr                Float?
  p50Ctr                Float?    // Median
  p75Ctr                Float?
  p90Ctr                Float?

  p25Cpc                Float?
  p50Cpc                Float?
  p75Cpc                Float?
  p90Cpc                Float?

  p25ConversionRate     Float?
  p50ConversionRate     Float?
  p75ConversionRate     Float?
  p90ConversionRate     Float?

  createdAt             DateTime  @default(now())

  @@unique([date, platform])
  @@index([date])
  @@map("benchmark_snapshots")
}
